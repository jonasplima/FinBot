# ===============================================================
# FINBOT - VARIAVEIS DE AMBIENTE
# ===============================================================
# Copie este arquivo para .env e preencha os valores

# ===============================================================
# APLICACAO
# ===============================================================
PORT=3003
LOG_LEVEL=INFO

# ===============================================================
# BANCO DE DADOS (PostgreSQL)
# ===============================================================
POSTGRES_USER=finbot
POSTGRES_PASSWORD=finbot_secure_password
POSTGRES_DB=finbot
DATABASE_URL=postgresql+asyncpg://finbot:finbot_secure_password@postgres:5432/finbot

# ===============================================================
# CACHE (Redis)
# ===============================================================
REDIS_PASSWORD=redis_secure_password
REDIS_URL=redis://:redis_secure_password@redis:6379

# ===============================================================
# EVOLUTION API (WhatsApp)
# ===============================================================
# URL base da Evolution API
# Exemplo: http://evolution-api:8080
EVOLUTION_API_URL=http://evolution-api:8080

# Gere uma chave segura com: openssl rand -hex 32
EVOLUTION_API_KEY=sua_chave_aqui

# Nome da instancia no Evolution API
EVOLUTION_INSTANCE=FinBot

# Numero opcional para bootstrap inicial da instancia no Evolution API
# Exemplo: 5511999999999
OWNER_PHONE=

# Numeros permitidos para rollout controlado (separados por virgula, opcional)
# Exemplo: 5511988888888,5511977777777
ALLOWED_NUMBERS=

# ===============================================================
# GOOGLE GEMINI (IA)
# ===============================================================
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=sua_chave_gemini

# ===============================================================
# SEGURANCA
# ===============================================================
# Senha para acessar endpoints administrativos via header Authorization
# Exemplo: Authorization: Bearer sua_senha_admin_secreta
# IMPORTANTE: Defina um valor forte em producao
ADMIN_SECRET=sua_senha_admin_secreta

# Segredo usado para autenticar chamadas do webhook da Evolution API
# Gere uma chave segura com: openssl rand -hex 32
WEBHOOK_SECRET=sua_chave_webhook_secreta

# ===============================================================
# SCHEDULER (Despesas Recorrentes)
# ===============================================================
# Habilitar/desabilitar o scheduler (default: true)
SCHEDULER_ENABLED=true

# Fuso horario para agendamento (default: America/Sao_Paulo)
SCHEDULER_TIMEZONE=America/Sao_Paulo

# Horario para executar job de recorrentes (formato 24h)
SCHEDULER_HOUR=8
SCHEDULER_MINUTE=0

# ===============================================================
# TERMOS E LIMITES PADRAO DE USO
# ===============================================================
# Versao atual dos termos exibidos no onboarding
TERMS_VERSION=2026-04

# Limites diarios padrao aplicados a novos usuarios
DEFAULT_DAILY_TEXT_LIMIT=100
DEFAULT_DAILY_MEDIA_LIMIT=20
DEFAULT_DAILY_AI_LIMIT=50

# ===============================================================
# LIMITES DEFENSIVOS DE ARQUIVOS
# ===============================================================
# Teto de PDF recebido para processamento automatico
MAX_PDF_SIZE_BYTES=2000000
MAX_PDF_PAGES=10
MAX_PDF_TEXT_CHARS=20000

# Teto de backup JSON recebido/exportado
MAX_BACKUP_SIZE_BYTES=1000000
MAX_BACKUP_EXPENSES=5000
MAX_BACKUP_BUDGETS=200
MAX_BACKUP_GOALS=200
MAX_BACKUP_BUDGET_ALERTS=1000
MAX_BACKUP_GOAL_UPDATES=1000

# Tempo de vida do backup temporario usado antes da confirmacao de restore
BACKUP_TEMP_TTL_SECONDS=600

# ===============================================================
# CONVERSAO DE MOEDA
# ===============================================================
# API Wise (primaria) - Crie em: https://wise.com/your-account/integrations-and-tools/api-tokens
# Deixe vazio para usar apenas ExchangeRate API ou fallback do banco
WISE_API_KEY=

# API ExchangeRate (fallback) - Obtenha em: https://www.exchangerate-api.com/
# Deixe vazio para usar apenas fallback do banco de dados
EXCHANGE_RATE_API_KEY=

# Tempo de cache das cotacoes em segundos (default: 3600 = 1 hora)
EXCHANGE_RATE_CACHE_TTL=3600

# Intervalo em dias para atualizar taxas no banco de dados (default: 7 = semanal)
FALLBACK_RATES_UPDATE_DAYS=7
