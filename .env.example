# ===============================================================
# FINBOT - VARIAVEIS DE AMBIENTE
# ===============================================================
# Copie este arquivo para .env e preencha os valores

# ===============================================================
# APLICACAO
# ===============================================================
PORT=3003
LOG_LEVEL=INFO

# ===============================================================
# BANCO DE DADOS (PostgreSQL)
# ===============================================================
POSTGRES_USER=finbot
POSTGRES_PASSWORD=finbot_secure_password
POSTGRES_DB=finbot
DATABASE_URL=postgresql+asyncpg://finbot:finbot_secure_password@postgres:5432/finbot

# ===============================================================
# CACHE (Redis)
# ===============================================================
REDIS_PASSWORD=redis_secure_password
REDIS_URL=redis://:redis_secure_password@redis:6379

# ===============================================================
# EVOLUTION API (WhatsApp)
# ===============================================================
# Gere uma chave segura com: openssl rand -hex 32
EVOLUTION_API_KEY=sua_chave_aqui

# Nome da instancia no Evolution API
EVOLUTION_INSTANCE=FinBot

# Seu numero de WhatsApp (com codigo do pais, sem +)
# Exemplo: 5511999999999
OWNER_PHONE=5511999999999

# Numeros adicionais permitidos (separados por virgula, opcional)
# Exemplo: 5511988888888,5511977777777
ALLOWED_NUMBERS=

# ===============================================================
# GOOGLE GEMINI (IA)
# ===============================================================
# Obtenha em: https://aistudio.google.com/apikey
GEMINI_API_KEY=sua_chave_gemini

# ===============================================================
# SEGURANCA
# ===============================================================
# Senha para acessar /admin/qrcode
# IMPORTANTE: Defina um valor forte em producao
ADMIN_SECRET=sua_senha_admin_secreta

# ===============================================================
# SCHEDULER (Despesas Recorrentes)
# ===============================================================
# Habilitar/desabilitar o scheduler (default: true)
SCHEDULER_ENABLED=true

# Fuso horario para agendamento (default: America/Sao_Paulo)
SCHEDULER_TIMEZONE=America/Sao_Paulo

# Horario para executar job de recorrentes (formato 24h)
SCHEDULER_HOUR=8
SCHEDULER_MINUTE=0
