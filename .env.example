# ===============================================================
# FINBOT - VARIAVEIS DE AMBIENTE
# ===============================================================
# Copie este arquivo para .env e preencha apenas o bloco abaixo.
# O restante desta pagina explica as variaveis opcionais e quando elas
# fazem sentido no projeto.

# ===============================================================
# PREENCHA ESTE BLOCO PARA RODAR O PROJETO
# ===============================================================

# PostgreSQL
POSTGRES_USER=finbot
POSTGRES_PASSWORD=troque_esta_senha_do_postgres
POSTGRES_DB=finbot
DATABASE_URL=postgresql+asyncpg://finbot:troque_esta_senha_do_postgres@postgres:5432/finbot

# Redis
REDIS_PASSWORD=troque_esta_senha_do_redis
REDIS_URL=redis://:troque_esta_senha_do_redis@redis:6379

# Evolution API / WhatsApp
EVOLUTION_API_URL=http://evolution-api:8080
EVOLUTION_API_KEY=preencha_com_a_chave_da_evolution
EVOLUTION_INSTANCE=FinBot

# IA
GEMINI_API_KEY=preencha_com_a_chave_do_gemini

# Seguranca basica da aplicacao
ADMIN_SECRET=defina_um_segredo_forte
WEBHOOK_SECRET=defina_um_segredo_forte_para_o_webhook

# ===============================================================
# VARIAVEIS OPCIONAIS E QUANDO USAR
# ===============================================================

# -------------------------------
# Aplicacao
# -------------------------------
# PORT
# Quando preencher: se quiser expor a API em uma porta diferente da 3003.
# Default recomendado: 3003
# PORT=3003

# LOG_LEVEL
# Quando preencher: se quiser mais ou menos verbosidade nos logs.
# Exemplos: DEBUG, INFO, WARNING, ERROR
# Default recomendado: INFO
# LOG_LEVEL=INFO

# -------------------------------
# Imagens de container
# -------------------------------
# Quando preencher: em producao, se quiser travar imagens por versao ou digest.
# Em ambiente local com Docker Compose, normalmente pode deixar o padrao do
# docker-compose.yml.
#
# POSTGRES_IMAGE=postgres:16-alpine
# REDIS_IMAGE=redis:7-alpine
# EVOLUTION_IMAGE=evoapicloud/evolution-api:v2.3.7
# PYTHON_BUILDER_IMAGE=python:3.12-slim
# PYTHON_RUNTIME_IMAGE=python:3.12-slim
#
# Em producao, prefira algo como:
# POSTGRES_IMAGE=postgres:16-alpine@sha256:...

# -------------------------------
# Bootstrap e rollout controlado
# -------------------------------
# OWNER_PHONE
# Quando preencher: se quiser informar um numero inicial de referencia para a
# instancia Evolution.
# Na maior parte dos casos pode ficar vazio.
# OWNER_PHONE=

# ALLOWED_NUMBERS
# Quando preencher: apenas se quiser restringir manualmente o uso inicial do bot
# a uma lista fechada de numeros, separada por virgula.
# Hoje o onboarding web ja autoriza o telefone da propria conta automaticamente,
# entao esta variavel e mais util para rollout controlado ou bootstrap.
# ALLOWED_NUMBERS=5511999999999,5511888888888

# -------------------------------
# IA adicional / fallback
# -------------------------------
# GROQ_API_KEY
# Quando preencher: se quiser usar Groq como fallback ou provedor principal.
# Se nao preencher, o sistema roda apenas com Gemini.
# GROQ_API_KEY=

# AI_PRIMARY_PROVIDER
# Quando preencher: se quiser trocar a ordem de prioridade entre Gemini e Groq.
# Valores aceitos: gemini | groq
# Se Groq nao estiver configurado, mantenha gemini.
# AI_PRIMARY_PROVIDER=gemini

# AI_TIMEOUT_SECONDS
# Quando preencher: se quiser aumentar ou reduzir o timeout das chamadas de IA.
# Default recomendado: 25
# AI_TIMEOUT_SECONDS=25

# -------------------------------
# Seguranca adicional
# -------------------------------
# APP_ENCRYPTION_KEY
# Quando preencher: recomendado em producao, para nao depender da derivacao a
# partir de outros segredos da instancia.
# Pode ser gerada com: openssl rand -hex 32
# APP_ENCRYPTION_KEY=

# ADMIN_RATE_LIMIT_MAX_ATTEMPTS
# ADMIN_RATE_LIMIT_WINDOW_SECONDS
# Quando preencher: se quiser ajustar o rate limit dos endpoints administrativos.
# Defaults recomendados:
# ADMIN_RATE_LIMIT_MAX_ATTEMPTS=10
# ADMIN_RATE_LIMIT_WINDOW_SECONDS=60

# WEB_SESSION_TTL_HOURS
# Quando preencher: se quiser mudar a duracao das sessoes web autenticadas.
# Default recomendado: 720 (30 dias)
# WEB_SESSION_TTL_HOURS=720

# -------------------------------
# Scheduler de recorrencias
# -------------------------------
# Quando preencher: se usar despesas recorrentes e quiser ajustar horario,
# timezone ou modo de deploy.
#
# SCHEDULER_ENABLED=true
# SCHEDULER_TIMEZONE=America/Sao_Paulo
# SCHEDULER_HOUR=8
# SCHEDULER_MINUTE=0
#
# DEPLOYMENT_MODE
# Valores:
# - single_instance: ambiente simples
# - multi_instance: replicas multiplas com lock distribuido
# DEPLOYMENT_MODE=single_instance
#
# SCHEDULER_LOCK_TTL_SECONDS=1800
# INSTANCE_ID=

# -------------------------------
# Termos e limites padrao para novas contas
# -------------------------------
# Quando preencher: se quiser mudar a versao dos termos ou os limites default
# aplicados a novos usuarios.
#
# TERMS_VERSION=2026-04
# DEFAULT_DAILY_TEXT_LIMIT=100
# DEFAULT_DAILY_MEDIA_LIMIT=20
# DEFAULT_DAILY_AI_LIMIT=50

# -------------------------------
# Limites defensivos de arquivos e webhook
# -------------------------------
# Quando preencher: se quiser endurecer ou flexibilizar processamento de PDFs,
# backups e idempotencia.
#
# MAX_PDF_SIZE_BYTES=2000000
# MAX_PDF_PAGES=10
# MAX_PDF_TEXT_CHARS=20000
#
# MAX_BACKUP_SIZE_BYTES=1000000
# MAX_BACKUP_EXPENSES=5000
# MAX_BACKUP_BUDGETS=200
# MAX_BACKUP_GOALS=200
# MAX_BACKUP_BUDGET_ALERTS=1000
# MAX_BACKUP_GOAL_UPDATES=1000
#
# BACKUP_TEMP_TTL_SECONDS=600
# WEBHOOK_IDEMPOTENCY_TTL_SECONDS=172800

# -------------------------------
# Conversao de moeda
# -------------------------------
# WISE_API_KEY
# Quando preencher: se quiser usar Wise como fonte primaria de cotacao ou valor
# real de conversao.
# WISE_API_KEY=

# EXCHANGE_RATE_API_KEY
# Quando preencher: se quiser uma segunda fonte de cotacao alem do fallback
# interno/banco de dados.
# EXCHANGE_RATE_API_KEY=

# EXCHANGE_RATE_CACHE_TTL
# FALLBACK_RATES_UPDATE_DAYS
# Quando preencher: se quiser ajustar cache e periodicidade de atualizacao.
# Defaults recomendados:
# EXCHANGE_RATE_CACHE_TTL=3600
# FALLBACK_RATES_UPDATE_DAYS=7
